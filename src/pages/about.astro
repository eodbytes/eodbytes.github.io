---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const values = [
  {
    icon: 'construction',
    title: 'Assembled, Not Hacked',
    desc: 'We don\'t build from scratch — we assemble from excellence. Our library ecosystem eliminates the MVP rewrite cycle and delivers production-grade architecture from the first sprint.',
    color: 'green',
  },
  {
    icon: 'shield',
    title: 'Compliance Is Built In',
    desc: 'App Store rejections. Play Store policy changes. Target API upgrades. We handle all five types of maintenance — corrective, adaptive, perfective, preventative, and emergency — as a core service.',
    color: 'blue',
  },
  {
    icon: 'groups',
    title: 'Your 1–2 Engineer Department',
    desc: 'We don\'t sell developers — we install a technical department. 1–2 embedded senior engineers with full access to our library ecosystem, architectural standards, and compliance infrastructure.',
    color: 'purple',
  },
];

---

<BaseLayout title="About EODbytes — Libraries-First Mobile Engineering" description="A production-first mobile engineering studio. We assemble apps from battle-tested libraries, eliminating the MVP rewrite cycle for Android and iOS.">
  <Header />

  <section class="about-page">
    <div class="container">
      <!-- Hero -->
      <div class="about-hero animate-fade-in-up">
        <div class="badge">
          <span class="material-symbols-outlined">groups</span>
          Our Mission
        </div>
        <h1 class="about-title">
          We industrialize mobile <span class="accent">excellence.</span>
        </h1>
        <p class="about-subtitle">
          EODbytes is a production-first mobile engineering studio. We reject the MVP-rewrite cycle. Instead, we assemble deployment-ready apps from a rigorously tested library ecosystem — faster, cheaper, and architecturally correct from the first commit.
        </p>
      </div>

      <!-- Philosophy Grid -->
      <div class="philosophy-grid">
        <!-- Dark Card -->
        <div class="philosophy-main reveal--left">
          <div class="icon-circle icon-circle--primary icon-circle--lg" style="margin-bottom: 2rem;">
            <span class="material-symbols-outlined" style="font-size: 2.5rem;">psychology</span>
          </div>
          <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 1.5rem;">The Libraries-First Philosophy</h2>
          <p class="philosophy-text">
            Most apps fail not because the idea was bad — but because the code couldn't scale. We call it the "vibe code" problem: software that works in a demo but collapses under real-world demands. Our response is architectural correctness from day one.
          </p>
          <p class="philosophy-text">
            We maintain a proprietary ecosystem of production-grade libraries — authentication, networking, persistence, state management — all pre-tested, compliant, and ready to assemble. This means 70–80% of your app's functionality is already hardened before a single line of custom code is written.
          </p>
          <p class="philosophy-text">
            AI accelerates our UI layer, but your business logic is written by senior engineers using deterministic, human-auditable code. No hallucinations in your payment processing.
          </p>
        </div>

        <!-- Value Cards -->
        <div class="values-col reveal--right">
          {values.map((item) => (
            <div class="card" style="padding: 2.5rem; display: flex; align-items: flex-start; gap: 1.5rem; border-radius: var(--radius-lg);">
              <div class={`icon-circle icon-circle--${item.color}`}>
                <span class="material-symbols-outlined" style="font-size: 1.5rem;">{item.icon}</span>
              </div>
              <div>
                <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">{item.title}</h3>
                <p style="color: var(--color-text-muted); line-height: 1.7;">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding-top: 2rem;
    padding-bottom: 5rem;
  }

  .about-hero {
    margin-bottom: 8rem;
    max-width: 56rem;
  }

  .about-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 2.5rem;
    margin-top: 2rem;
  }

  .about-subtitle {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Philosophy */
  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    margin-bottom: 8rem;
  }

  @media (min-width: 769px) {
    .philosophy-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .philosophy-main {
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: 3rem;
    border-radius: var(--radius-3xl);
    box-shadow: var(--shadow-2xl);
  }

  .philosophy-text {
    font-size: 1.25rem;
    color: var(--color-white-80);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .philosophy-text:last-child {
    margin-bottom: 0;
  }

  .values-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

</style>
