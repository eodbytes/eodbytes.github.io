---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const steps = [
  {
    id: '01',
    title: 'Readiness Assessment',
    description: 'We audit your existing codebase (or define your greenfield requirements) to identify which components from our library ecosystem can be deployed immediately, and what needs to be custom-built. You receive a detailed technical blueprint and cost estimate.',
    icon: 'search',
  },
  {
    id: '02',
    title: 'Library Assembly & Architecture',
    description: 'We configure the foundational libraries — authentication, networking, data persistence, state management, navigation — into your app\'s architecture. On a KMP project, this means up to 80% of your codebase is production-ready before any feature-specific work begins.',
    icon: 'construction',
  },
  {
    id: '03',
    title: 'Feature Engineering & AI-Powered UI',
    description: 'Senior engineers build your custom business logic using Kotlin and Clean Architecture patterns. AI accelerates the UI layer — converting designs to Compose/SwiftUI code at speed — while business logic remains strictly human-written and auditable.',
    icon: 'code',
  },
  {
    id: '04',
    title: 'Quality Assurance & Compliance',
    description: 'Comprehensive unit, integration, and UI testing. We validate compliance with the latest App Store and Play Store policies — privacy manifests, data safety declarations, target API levels — before submission.',
    icon: 'verified',
  },
  {
    id: '05',
    title: 'Launch & Managed Maintenance',
    description: 'We manage the store submission process, set up crash reporting and analytics, and transition into ongoing managed maintenance. Library updates, OS compatibility patches, and security fixes are handled proactively — not reactively.',
    icon: 'rocket_launch',
  },
];
---

<BaseLayout title="Our Process — Assembly, Not Construction | EODbytes" description="How we build production-ready mobile apps: readiness assessment, library assembly, AI-powered UI, compliance QA, and managed maintenance.">
  <Header />

  <section class="process-page">
    <div class="process-container">
      <!-- Header -->
      <div class="process-header animate-fade-in-up">
        <div class="badge">
          <span class="material-symbols-outlined">settings</span>
          Our Methodology
        </div>
        <h1 class="process-title">Assembly, Not Construction</h1>
        <p class="process-subtitle">
          Traditional agencies build from scratch. We assemble from a pre-validated library ecosystem — cutting delivery time, eliminating architectural debt, and ensuring compliance from sprint one.
        </p>
      </div>

      <!-- Vertical Timeline -->
      <div class="timeline">
        <div class="timeline-line"></div>

        {steps.map((step, index) => (
          <div class={`timeline-item ${index % 2 === 0 ? 'timeline-item--right' : 'timeline-item--left'} reveal`}
               style={`transition-delay: ${index * 0.1}s;`}>
            <!-- Node -->
            <div class="timeline-node">
              <span class="material-symbols-outlined" style="font-size: 1.75rem; color: var(--color-primary);">
                {step.icon}
              </span>
            </div>

            <!-- Content -->
            <div class="timeline-content">
              <div class="card card--rounded" style="padding: 2rem 2.5rem;">
                <div class="timeline-step-id">{step.id}</div>
                <h3 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem;">{step.title}</h3>
                <p style="color: var(--color-text-muted); line-height: 1.7; font-size: 1.1rem;">{step.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .process-page {
    min-height: 100vh;
    padding-top: 2rem;
    padding-bottom: 5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .process-container {
    max-width: 56rem;
    margin: 0 auto;
  }

  .process-header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .process-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    margin-top: 1.5rem;
  }

  .process-subtitle {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Timeline */
  .timeline {
    position: relative;
  }

  .timeline-line {
    position: absolute;
    left: 2.4rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border-light);
  }

  @media (min-width: 769px) {
    .timeline-line {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .timeline-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 4rem;
    padding-left: 5rem;
  }

  @media (min-width: 769px) {
    .timeline-item {
      padding-left: 0;
      gap: 4rem;
    }

    .timeline-item--right {
      flex-direction: row-reverse;
    }

    .timeline-item--right .timeline-content {
      text-align: right;
    }
  }

  .timeline-node {
    position: absolute;
    left: 0;
    width: 4.8rem;
    height: 4.8rem;
    background: var(--color-bg-light);
    border: 4px solid var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    box-shadow: 0 8px 24px rgba(255, 79, 15, 0.2);
  }

  @media (min-width: 769px) {
    .timeline-node {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .timeline-content {
    flex: 1;
  }

  @media (min-width: 769px) {
    .timeline-content {
      width: 50%;
      flex: none;
    }

    .timeline-item--right .timeline-content {
      padding-right: 2rem;
    }

    .timeline-item--left .timeline-content {
      padding-left: 2rem;
    }
  }

  .timeline-step-id {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-primary);
    opacity: 0.2;
    margin-bottom: 1rem;
  }
</style>
