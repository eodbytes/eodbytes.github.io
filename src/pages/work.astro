---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const projects = [
  {
    id: 1,
    title: 'Fintech App',
    category: 'KMP',
    image: 'https://picsum.photos/seed/fintech/800/600',
    description: 'A cross-platform banking application built with Kotlin Multiplatform Mobile, sharing 80% of business logic across iOS and Android.',
    tech: ['Kotlin Multiplatform', 'SwiftUI', 'Jetpack Compose'],
  },
  {
    id: 2,
    title: 'Health Tracker',
    category: 'Native Android',
    image: 'https://picsum.photos/seed/health/800/600',
    description: 'A native Android health and fitness tracking application utilizing modern Android architecture and Jetpack Compose.',
    tech: ['Kotlin', 'Jetpack Compose', 'Coroutines', 'Room'],
  },
  {
    id: 3,
    title: 'E-commerce Platform',
    category: 'Native iOS',
    image: 'https://picsum.photos/seed/ecommerce/800/600',
    description: 'A high-performance native iOS e-commerce application built with SwiftUI and Combine for a seamless shopping experience.',
    tech: ['Swift', 'SwiftUI', 'Combine', 'CoreData'],
  },
  {
    id: 4,
    title: 'Social Network',
    category: 'KMP',
    image: 'https://picsum.photos/seed/social/800/600',
    description: 'A social networking platform leveraging KMP for shared networking, caching, and data models.',
    tech: ['Ktor', 'SQLDelight', 'KMP'],
  },
  {
    id: 5,
    title: 'IoT Controller',
    category: 'Native Android',
    image: 'https://picsum.photos/seed/iot/800/600',
    description: 'An Android application for controlling smart home devices via Bluetooth Low Energy (BLE).',
    tech: ['Kotlin', 'BLE', 'Coroutines'],
  },
  {
    id: 6,
    title: 'Travel Guide',
    category: 'Native iOS',
    image: 'https://picsum.photos/seed/travel/800/600',
    description: 'A beautifully designed iOS travel guide application with offline maps and location-based recommendations.',
    tech: ['Swift', 'MapKit', 'CoreLocation'],
  },
];

const categories = ['All', 'KMP', 'Native Android', 'Native iOS'];
---

<BaseLayout title="Our Work - EODbytes" description="Explore our portfolio of mobile apps built with Kotlin Multiplatform, Android, and iOS.">
  <Header />

  <section class="work-page">
    <div class="container">
      <!-- Header -->
      <div class="work-header animate-fade-in-up">
        <h1 class="work-title">Our Work</h1>
        <p class="work-subtitle">
          We partner with ambitious companies to build mobile products that define categories and delight users.
        </p>
      </div>

      <!-- Filters -->
      <div class="filters animate-fade-in-up delay-2">
        {categories.map((cat) => (
          <button
            class:list={['filter-btn', { active: cat === 'All' }]}
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Project Grid -->
      <div class="project-grid" id="project-grid">
        {projects.map((project, i) => (
          <div class={`project-card reveal delay-${(i % 3) + 1}`} data-category={project.category}>
            <div class="project-image-wrap">
              <img
                src={project.image}
                alt={project.title}
                referrerpolicy="no-referrer"
                class="project-image"
                loading="lazy"
              />
              <div class="project-overlay">
                <div class="project-overlay-btn">
                  View Case Study
                  <span class="material-symbols-outlined" style="font-size: 0.875rem;">arrow_forward</span>
                </div>
              </div>
              <div class="project-badge">{project.category}</div>
            </div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-tech">
              {project.tech.map((t) => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .work-page {
    min-height: 100vh;
    padding-top: 8rem;
    padding-bottom: 5rem;
  }

  .work-header {
    margin-bottom: 5rem;
  }

  .work-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
  }

  .work-subtitle {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    max-width: 48rem;
    line-height: 1.6;
  }

  /* Filters */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .filter-btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.875rem;
    transition: all 0.3s ease;
    background: white;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-light);
  }

  .filter-btn:hover {
    background: rgba(0, 0, 0, 0.03);
  }

  .filter-btn.active {
    background: var(--color-text-dark);
    color: var(--color-text-light);
    border-color: var(--color-text-dark);
    box-shadow: var(--shadow-md);
  }

  /* Project Grid */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 769px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project-card {
    cursor: pointer;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .project-card.hidden {
    display: none;
  }

  .project-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    aspect-ratio: 4 / 3;
    background: rgba(0, 0, 0, 0.03);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .project-card:hover .project-image {
    transform: scale(1.05);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.2);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-overlay-btn {
    background: white;
    color: var(--color-text-dark);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transform: translateY(10px);
    transition: transform 0.3s ease;
    font-size: 0.9rem;
  }

  .project-card:hover .project-overlay-btn {
    transform: translateY(0);
  }

  .project-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-dark);
  }

  .project-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
  }

  .project-card:hover .project-title {
    color: var(--color-primary);
  }

  .project-desc {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.6;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-text-dark);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }
</style>

<script>
  // Filter functionality (replaces React useState)
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active button
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter cards
      projectCards.forEach((card) => {
        const category = card.getAttribute('data-category');
        if (filter === 'All' || category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
