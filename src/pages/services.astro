---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const services = [
  {
    title: 'Production App Build',
    icon: 'rocket_launch',
    description: 'Start with production-grade architecture, not a throwaway MVP. Our library ecosystem means 70–80% of functionality — auth, networking, persistence, state management — is already tested and compliant. You launch a real product, not a prototype.',
    features: ['Libraries-First Architecture', 'Kotlin Multiplatform + Compose', 'Prod-Level from Sprint 1', 'Store-Compliant from Day 1'],
  },
  {
    title: 'App 2.0 — The Reshape',
    icon: 'build',
    description: 'Your app has market validation but the code can\'t scale. Constant crashes, slow feature delivery, dependency nightmares. We reshape your existing product using our hardened library framework — preserving what works while replacing what doesn\'t.',
    features: ['Codebase Architecture Audit', 'Systematic Library Transplant', 'Zero Downtime Transition', 'Performance & Security Uplift'],
  },
  {
    title: 'Managed Maintenance & Compliance',
    icon: 'verified_user',
    description: 'Making an app is not the difficult part — staying compliant and keeping libraries updated is. We handle all five types of maintenance as a core service, so your app never gets rejected, breached, or left behind.',
    features: ['Corrective (Bug Fixes & Crashes)', 'Adaptive (OS & Device Updates)', 'Preventative (Library Updates)', 'Emergency (Critical Patches)'],
  },
  {
    title: 'Embedded Engineering Team',
    icon: 'groups',
    description: 'Don\'t hire a full engineering team from scratch. We embed 1–2 senior engineers directly into your organization — with full access to our library ecosystem, architectural standards, and compliance infrastructure.',
    features: ['Dedicated Senior Engineers', 'Full Library Ecosystem Access', 'Compliance & Dependency Mgmt', 'Scales with Your Business'],
  },
];
---

<BaseLayout title="Services — Production Builds, App 2.0 Reshapes & Managed Maintenance | EODbytes" description="From greenfield production builds to rescuing messy codebases. KMP development, App 2.0 reshapes, managed maintenance, and embedded engineering teams.">
  <Header />
  <section class="services-page">
    <div class="container">
      <div class="services-header animate-fade-in-up">
        <div class="badge">
          <span class="material-symbols-outlined">construction</span>
          What We Do
        </div>
        <h1 class="services-title">Production-Ready Engineering</h1>
        <p class="services-subtitle">From greenfield builds to rescuing messy codebases, we use our libraries-first methodology to deliver apps that are deployment-ready from the start — no MVP phase, no rewrite required.</p>
      </div>
      <div class="services-grid">
        {services.map((service, i) => (
          <div class={`service-card reveal delay-${(i % 2) + 1}`}>
            <div class="svc-icon icon-circle icon-circle--primary icon-circle--lg">
              <span class="material-symbols-outlined" style="font-size: 2.5rem;">{service.icon}</span>
            </div>
            <h2 class="service-title">{service.title}</h2>
            <p class="service-desc">{service.description}</p>
            <ul class="service-features">
              {service.features.map((f) => (
                <li class="service-feature">
                  <span class="material-symbols-outlined" style="font-size: 0.875rem; color: var(--color-primary);">check_circle</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="services-cta reveal--scale">
        <div class="services-cta-glow"></div>
        <div class="services-cta-content">
          <h2 class="cta-heading">The MVP rewrite is the most expensive mistake in mobile.</h2>
          <p class="cta-text">The average startup spends $120K over 18 months on the MVP-then-rewrite path. Our libraries-first approach delivers the same outcome for $65K — and your Year 1 maintenance is included.</p>
          <a href="/contact/" class="btn btn--primary btn--lg">Get a Free Readiness Assessment <span class="material-symbols-outlined">arrow_forward</span></a>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>

<style>
  .services-page { min-height: 100vh; padding-top: 2rem; padding-bottom: 5rem; }
  .services-header { text-align: center; margin-bottom: 6rem; }
  .services-title { font-size: clamp(3rem, 8vw, 5rem); font-weight: 900; letter-spacing: -0.04em; margin: 1.5rem 0 2rem; }
  .services-subtitle { font-size: 1.5rem; color: var(--color-text-muted); line-height: 1.6; max-width: 48rem; margin: 0 auto; }
  .services-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 8rem; }
  @media (min-width: 769px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  .service-card { background: white; padding: 2.5rem; border-radius: var(--radius-2xl); border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); transition: all 0.3s ease; }
  .service-card:hover { box-shadow: var(--shadow-xl); }
  .svc-icon { border-radius: var(--radius-xl); margin-bottom: 2rem; transition: transform 0.3s; }
  .service-card:hover .svc-icon { transform: scale(1.1); }
  .service-title { font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem; transition: color 0.2s; }
  .service-card:hover .service-title { color: var(--color-primary); }
  .service-desc { color: var(--color-text-muted); line-height: 1.7; font-size: 1.1rem; margin-bottom: 2rem; }
  .service-features { display: flex; flex-direction: column; gap: 0.75rem; }
  .service-feature { display: flex; align-items: center; gap: 0.75rem; font-weight: 500; }
  .services-cta { background: var(--color-bg-dark); color: var(--color-text-light); border-radius: var(--radius-3xl); padding: 3rem; text-align: center; box-shadow: var(--shadow-2xl); position: relative; overflow: hidden; }
  @media (min-width: 769px) { .services-cta { padding: 5rem; } }
  .services-cta-glow { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,79,15,0.2), transparent); opacity: 0.5; }
  .services-cta-content { position: relative; z-index: 10; }
  .cta-heading { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 900; letter-spacing: -0.04em; margin-bottom: 2rem; }
  .cta-text { font-size: 1.5rem; color: var(--color-white-80); max-width: 48rem; margin: 0 auto 3rem; line-height: 1.6; }
</style>
