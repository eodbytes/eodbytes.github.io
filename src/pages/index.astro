---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const services = [
  {
    icon: 'devices',
    title: 'Kotlin Multiplatform',
    desc: 'Share business logic across iOS and Android while maintaining 100% native UI performance and feel.',
  },
  {
    icon: 'android',
    title: 'Native Android',
    desc: 'Deep expertise in Kotlin, Jetpack Compose, Coroutines, and modern Android architecture.',
  },
  {
    icon: 'phone_iphone',
    title: 'Native iOS',
    desc: 'Swift, SwiftUI, and Combine. We build fluid, Apple-standard experiences that users love.',
  },
];
---

<BaseLayout title="EODbytes - Mobile Engineering Studio">
  <Header />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content animate-fade-in-up">
        <div class="badge">
          <span class="material-symbols-outlined">rocket_launch</span>
          Mobile Engineering Studio
        </div>
        <h1 class="hero-title">
          We build <span class="accent">premium</span> mobile experiences.
        </h1>
        <p class="hero-subtitle">
          Specializing in Kotlin Multiplatform, native Android, and iOS. We transform complex technical challenges into
          elegant, high-performance applications.
        </p>
        <div class="hero-actions">
          <a href="/work/" class="btn btn--primary">
            View Our Work
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="/contact/" class="btn btn--outline"> Start a Project </a>
        </div>
      </div>

      <!-- Hero Visual -->
      <div class="hero-visual animate-scale-in delay-2">
        <div class="hero-glow"></div>

        <!-- Phone Mockup -->
        <div class="phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-content">
            <div class="phone-block phone-block--lg animate-pulse"></div>
            <div class="phone-row">
              <div class="phone-block phone-block--accent animate-pulse" style="animation-delay: 75ms;"></div>
              <div class="phone-block animate-pulse" style="animation-delay: 150ms;"></div>
            </div>
            <div class="phone-block phone-block--bar animate-pulse"></div>
          </div>
        </div>

        <!-- Floating Elements -->
        <div class="floating-card floating-card--top animate-float">
          <div class="icon-circle icon-circle--primary icon-circle--sm">
            <span class="material-symbols-outlined">code</span>
          </div>
          <div>
            <p class="floating-label">Tech Stack</p>
            <p class="floating-value">Kotlin Multiplatform</p>
          </div>
        </div>

        <div class="floating-card floating-card--bottom animate-float-alt">
          <div class="icon-circle icon-circle--green icon-circle--sm">
            <span class="material-symbols-outlined">speed</span>
          </div>
          <div>
            <p class="floating-label">Performance</p>
            <p class="floating-value">60fps Native</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats">
    <div class="stats-inner">
      <div class="stat">
        <h3 class="stat-number">50+</h3>
        <p class="stat-label">Apps Shipped</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">4.9</h3>
        <p class="stat-label">App Store Avg</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">10M+</h3>
        <p class="stat-label">Active Users</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">0</h3>
        <p class="stat-label">Technical Debt</p>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="services-preview section">
    <div class="container">
      <div class="services-header">
        <div>
          <h2 class="section-title reveal">Engineering Excellence</h2>
          <p class="section-subtitle reveal delay-1">
            We don't just write code; we architect scalable, maintainable mobile solutions that drive business growth.
          </p>
        </div>
        <a href="/services/" class="services-link hide-mobile reveal">
          All Services <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>

      <div class="services-grid">
        {
          services.map((service, i) => (
            <div class={`card card--rounded reveal delay-${i + 1}`}>
              <div class="icon-circle icon-circle--primary" style="border-radius: var(--radius-xl); margin-bottom: 1.5rem;">
                <span class="material-symbols-outlined" style="font-size: 1.75rem;">
                  {service.icon}
                </span>
              </div>
              <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">{service.title}</h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">{service.desc}</p>
            </div>
          ))
        }
      </div>

      <div class="hide-desktop" style="margin-top: 2rem; text-align: center;">
        <a href="/services/" class="services-link">
          All Services <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="cta-inner reveal--scale">
      <h2 class="cta-title">Ready to build something extraordinary?</h2>
      <p class="cta-subtitle">
        Let's discuss your mobile strategy and how our engineering team can accelerate your roadmap.
      </p>
      <a href="/contact/" class="btn btn--dark btn--lg">
        Schedule a Discovery Call
        <span class="material-symbols-outlined">calendar_month</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    padding: 8rem 1.5rem 5rem;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero-content {
    position: relative;
    z-index: 10;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 2rem;
    margin-top: 2rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
    }
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
  }

  @media (min-width: 1024px) {
    .hero-visual {
      min-height: 600px;
    }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(255, 79, 15, 0.15), transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
  }

  .phone-mockup {
    position: relative;
    width: 280px;
    height: 560px;
    background: var(--color-bg-dark);
    border-radius: 3rem;
    border: 8px solid var(--color-text-dark);
    box-shadow: var(--shadow-2xl);
    overflow: hidden;
    z-index: 10;
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    height: 1.5rem;
    background: var(--color-text-dark);
    border-radius: 0 0 1.5rem 1.5rem;
  }

  .phone-content {
    padding: 1.5rem;
    padding-top: 4rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .phone-block {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
  }

  .phone-block--lg {
    width: 100%;
    height: 8rem;
  }

  .phone-block--accent {
    background: rgba(255, 79, 15, 0.2);
  }

  .phone-row {
    display: flex;
    gap: 1rem;
  }

  .phone-row .phone-block {
    flex: 1;
    height: 6rem;
  }

  .phone-block--bar {
    width: 100%;
    height: 3rem;
    border-radius: 0.75rem;
    margin-top: auto;
  }

  /* Floating Cards */
  .floating-card {
    position: absolute;
    background: white;
    padding: 1rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .floating-card--top {
    top: 3rem;
    left: -1rem;
  }

  .floating-card--bottom {
    bottom: 6rem;
    right: -1rem;
  }

  @media (max-width: 1023px) {
    .floating-card--top {
      top: 1rem;
      left: 0;
    }
    .floating-card--bottom {
      bottom: 3rem;
      right: 0;
    }
  }

  .floating-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .floating-value {
    font-weight: 600;
    color: var(--color-text-dark);
    font-size: 0.95rem;
  }

  /* --- Stats --- */
  .stats {
    padding: 5rem 1.5rem;
    background: var(--color-bg-dark);
    color: var(--color-text-light);
  }

  .stats-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .stats-inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat {
    text-align: center;
    padding: 1rem;
  }

  .stat + .stat {
    border-left: 1px solid var(--color-white-10);
  }

  @media (max-width: 768px) {
    .stat:nth-child(odd) {
      border-left: none;
    }
    .stat:nth-child(3),
    .stat:nth-child(4) {
      border-top: 1px solid var(--color-white-10);
    }
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--color-white-70);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
  }

  /* --- Services Preview --- */
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 40rem;
  }

  .services-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: color 0.2s;
  }
  .services-link:hover {
    color: var(--color-primary-dark);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- CTA --- */
  .cta {
    padding: 8rem 1.5rem;
    background: var(--color-primary);
    color: var(--color-text-light);
    text-align: center;
  }

  .cta-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .cta-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--color-white-90);
    max-width: 40rem;
    margin: 0 auto 3rem;
    font-weight: 500;
  }
</style>
