---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const services = [
  {
    icon: 'construction',
    title: 'Build from Tested Libraries',
    desc: '70–80% of app functionality is standardized in our pre-validated library ecosystem — auth, networking, persistence, state management — all architecturally correct from day one.',
  },
  {
    icon: 'devices',
    title: 'Ship to Both Platforms',
    desc: 'Kotlin Multiplatform shares business logic natively across iOS and Android. No cross-platform compromises — 100% native performance with the Compose + SwiftUI rendering pipeline.',
  },
  {
    icon: 'verified_user',
    title: 'Stay Compliant, Always',
    desc: 'App Store and Play Store policies change constantly. Our managed maintenance handles adaptive updates, security patches, and dependency upgrades — so your app never falls behind.',
  },
];
---

<BaseLayout title="EODbytes — Production-Ready Mobile Apps | Kotlin Multiplatform Studio">
  <Header />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content animate-fade-in-up">
        <div class="badge">
          <span class="material-symbols-outlined">library_books</span>
          Libraries-First Engineering
        </div>
        <h1 class="hero-title">
          We don't build MVPs. We build <span class="accent">production-ready</span> apps.
        </h1>
        <p class="hero-subtitle">
          Skip the throwaway prototype. Our pre-tested library ecosystem delivers deployment-ready mobile apps on Kotlin Multiplatform — no rewrite cycle, no technical debt, no compliance headaches.
        </p>
        <div class="hero-actions">
          <a href="/process/" class="btn btn--primary">
            See How We Build
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
          <a href="/contact/" class="btn btn--outline"> Start a Project </a>
        </div>
      </div>

      <!-- Hero Visual -->
      <div class="hero-visual animate-scale-in delay-2">
        <div class="hero-glow"></div>

        <!-- Phone Mockup -->
        <div class="phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-content">
            <div class="phone-block phone-block--lg animate-pulse"></div>
            <div class="phone-row">
              <div class="phone-block phone-block--accent animate-pulse" style="animation-delay: 75ms;"></div>
              <div class="phone-block animate-pulse" style="animation-delay: 150ms;"></div>
            </div>
            <div class="phone-block phone-block--bar animate-pulse"></div>
          </div>
        </div>

        <!-- Floating Elements -->
        <div class="floating-card floating-card--top animate-float">
          <div class="icon-circle icon-circle--primary icon-circle--sm">
            <span class="material-symbols-outlined">code</span>
          </div>
          <div>
            <p class="floating-label">Architecture</p>
            <p class="floating-value">Libraries-First</p>
          </div>
        </div>

        <div class="floating-card floating-card--bottom animate-float-alt">
          <div class="icon-circle icon-circle--green icon-circle--sm">
            <span class="material-symbols-outlined">speed</span>
          </div>
          <div>
            <p class="floating-label">Time-to-Market</p>
            <p class="floating-value">40% Faster</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats">
    <div class="stats-inner">
      <div class="stat">
        <h3 class="stat-number">80%+</h3>
        <p class="stat-label">Code Shared</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">Day 1</h3>
        <p class="stat-label">Prod-Ready</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">100%</h3>
        <p class="stat-label">Store-Compliant</p>
      </div>
      <div class="stat">
        <h3 class="stat-number">45%</h3>
        <p class="stat-label">Lower TCO</p>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="services-preview section">
    <div class="container">
      <div class="services-header">
        <div>
          <h2 class="section-title reveal">The Libraries-First Advantage</h2>
          <p class="section-subtitle reveal delay-1">
            While others hack together MVPs, we assemble production apps from our ecosystem of battle-tested libraries. Faster delivery. Zero architectural debt.
          </p>
        </div>
        <a href="/services/" class="services-link hide-mobile reveal">
          All Services <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>

      <div class="services-grid">
        {
          services.map((service, i) => (
            <div class={`card card--rounded reveal delay-${i + 1}`}>
              <div class="icon-circle icon-circle--primary" style="border-radius: var(--radius-xl); margin-bottom: 1.5rem;">
                <span class="material-symbols-outlined" style="font-size: 1.75rem;">
                  {service.icon}
                </span>
              </div>
              <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">{service.title}</h3>
              <p style="color: var(--color-text-muted); line-height: 1.7;">{service.desc}</p>
            </div>
          ))
        }
      </div>

      <div class="hide-desktop" style="margin-top: 2rem; text-align: center;">
        <a href="/services/" class="services-link">
          All Services <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Cost Comparison Section -->
  <section class="comparison section">
    <div class="container">
      <div class="comparison-header">
        <h2 class="section-title reveal">The Real Cost of an MVP</h2>
        <p class="section-subtitle reveal delay-1">
          The MVP-then-rewrite path costs nearly double over 18 months. Our libraries-first approach eliminates the rewrite entirely.
        </p>
      </div>

      <div class="comparison-grid">
        <!-- MVP Path -->
        <div class="comparison-card comparison-card--faded reveal--left">
          <div class="comparison-label">Traditional MVP Path</div>
          <div class="comparison-total">~$120K</div>
          <p class="comparison-period">over 18 months</p>
          <ul class="comparison-list">
            <li>
              <span class="comparison-item-label">Launch (0–4 mo)</span>
              <span class="comparison-item-value">$45,000</span>
            </li>
            <li>
              <span class="comparison-item-label">Scale & Rewrite (6–12 mo)</span>
              <span class="comparison-item-value">$60,000</span>
            </li>
            <li>
              <span class="comparison-item-label">Maintenance (Year 1)</span>
              <span class="comparison-item-value">$15,000</span>
            </li>
          </ul>
          <div class="comparison-verdict comparison-verdict--negative">
            <span class="material-symbols-outlined" style="font-size: 1.25rem;">warning</span>
            Rewrite required to scale
          </div>
        </div>

        <!-- EODbytes Path -->
        <div class="comparison-card comparison-card--highlighted reveal--right">
          <div class="comparison-badge">Recommended</div>
          <div class="comparison-label">Libraries-First Path</div>
          <div class="comparison-total comparison-total--accent">~$65K</div>
          <p class="comparison-period">over 18 months</p>
          <ul class="comparison-list">
            <li>
              <span class="comparison-item-label">Launch (0–4 mo)</span>
              <span class="comparison-item-value">$55,000</span>
            </li>
            <li>
              <span class="comparison-item-label">Scale (6–12 mo)</span>
              <span class="comparison-item-value">$10,000</span>
            </li>
            <li>
              <span class="comparison-item-label">Maintenance (Year 1)</span>
              <span class="comparison-item-value">Included</span>
            </li>
          </ul>
          <div class="comparison-verdict comparison-verdict--positive">
            <span class="material-symbols-outlined" style="font-size: 1.25rem;">check_circle</span>
            Production-ready from day one
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Roadmap Section -->
  <section class="roadmap section--compact">
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <div class="badge reveal" style="margin-bottom: 1.5rem;">
          <span class="material-symbols-outlined">timeline</span>
          Coming Soon
        </div>
        <h2 class="section-title reveal delay-1">The Roadmap</h2>
        <p class="section-subtitle reveal delay-2" style="margin: 0 auto;">
          We're building toward a complete Product OS — so you have everything you need from build to growth, in one place.
        </p>
      </div>

      <div class="roadmap-grid">
        <div class="card card--rounded reveal delay-1" style="padding: 2.5rem; text-align: center;">
          <div class="icon-circle icon-circle--primary" style="border-radius: var(--radius-xl); margin: 0 auto 1.5rem;">
            <span class="material-symbols-outlined" style="font-size: 1.75rem;">dns</span>
          </div>
          <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Custom Backend</h3>
          <p style="color: var(--color-text-muted); line-height: 1.7;">Full-stack Kotlin consistency. Share data models and business logic between your mobile apps and backend — eliminating API mismatches.</p>
        </div>
        <div class="card card--rounded reveal delay-2" style="padding: 2.5rem; text-align: center;">
          <div class="icon-circle icon-circle--green" style="border-radius: var(--radius-xl); margin: 0 auto 1.5rem;">
            <span class="material-symbols-outlined" style="font-size: 1.75rem;">storefront</span>
          </div>
          <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Store Automation</h3>
          <p style="color: var(--color-text-muted); line-height: 1.7;">Automated App Store Optimization analytics with real-time download data. Test the virality of an idea before committing resources.</p>
        </div>
        <div class="card card--rounded reveal delay-3" style="padding: 2.5rem; text-align: center;">
          <div class="icon-circle icon-circle--purple" style="border-radius: var(--radius-xl); margin: 0 auto 1.5rem;">
            <span class="material-symbols-outlined" style="font-size: 1.75rem;">monitoring</span>
          </div>
          <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Social Tracking</h3>
          <p style="color: var(--color-text-muted); line-height: 1.7;">Unified marketing ROI across all social platforms. One dashboard to track user acquisition, engagement, and conversion from every channel.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="cta-inner reveal--scale">
      <h2 class="cta-title">Is your app built on vibe code?</h2>
      <p class="cta-subtitle">
        Whether you're starting fresh or rescuing a messy codebase, our libraries-first approach gets you to production faster — and keeps you there.
      </p>
      <a href="/contact/" class="btn btn--dark btn--lg">
        Get a Free Architecture Assessment
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    padding: 2rem 1.5rem 5rem;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero-content {
    position: relative;
    z-index: 10;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 2rem;
    margin-top: 2rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
    }
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
  }

  @media (min-width: 1024px) {
    .hero-visual {
      min-height: 600px;
    }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(255, 79, 15, 0.15), transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
  }

  .phone-mockup {
    position: relative;
    width: 280px;
    height: 560px;
    background: var(--color-bg-dark);
    border-radius: 3rem;
    border: 8px solid var(--color-text-dark);
    box-shadow: var(--shadow-2xl);
    overflow: hidden;
    z-index: 10;
  }

  .phone-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    height: 1.5rem;
    background: var(--color-text-dark);
    border-radius: 0 0 1.5rem 1.5rem;
  }

  .phone-content {
    padding: 1.5rem;
    padding-top: 4rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .phone-block {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
  }

  .phone-block--lg {
    width: 100%;
    height: 8rem;
  }

  .phone-block--accent {
    background: rgba(255, 79, 15, 0.2);
  }

  .phone-row {
    display: flex;
    gap: 1rem;
  }

  .phone-row .phone-block {
    flex: 1;
    height: 6rem;
  }

  .phone-block--bar {
    width: 100%;
    height: 3rem;
    border-radius: 0.75rem;
    margin-top: auto;
  }

  /* Floating Cards */
  .floating-card {
    position: absolute;
    background: white;
    padding: 1rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .floating-card--top {
    top: 3rem;
    left: -1rem;
  }

  .floating-card--bottom {
    bottom: 6rem;
    right: -1rem;
  }

  @media (max-width: 1023px) {
    .floating-card--top {
      top: 1rem;
      left: 0;
    }
    .floating-card--bottom {
      bottom: 3rem;
      right: 0;
    }
  }

  .floating-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .floating-value {
    font-weight: 600;
    color: var(--color-text-dark);
    font-size: 0.95rem;
  }

  /* --- Stats --- */
  .stats {
    padding: 5rem 1.5rem;
    background: var(--color-bg-dark);
    color: var(--color-text-light);
  }

  .stats-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .stats-inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat {
    text-align: center;
    padding: 1rem;
  }

  .stat + .stat {
    border-left: 1px solid var(--color-white-10);
  }

  @media (max-width: 768px) {
    .stat:nth-child(odd) {
      border-left: none;
    }
    .stat:nth-child(3),
    .stat:nth-child(4) {
      border-top: 1px solid var(--color-white-10);
    }
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--color-white-70);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.875rem;
  }

  /* --- Services Preview --- */
  .services-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 40rem;
  }

  .services-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: color 0.2s;
  }
  .services-link:hover {
    color: var(--color-primary-dark);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- CTA --- */
  .cta {
    padding: 8rem 1.5rem;
    background: var(--color-primary);
    color: var(--color-text-light);
    text-align: center;
  }

  .cta-inner {
    max-width: 56rem;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .cta-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--color-white-90);
    max-width: 40rem;
    margin: 0 auto 3rem;
    font-weight: 500;
  }

  /* --- Comparison --- */
  .comparison-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  @media (min-width: 769px) {
    .comparison-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .comparison-card {
    background: white;
    border-radius: var(--radius-2xl);
    padding: 2.5rem;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    position: relative;
  }

  .comparison-card--faded {
    opacity: 0.85;
  }

  .comparison-card--highlighted {
    border: 2px solid var(--color-primary);
    box-shadow: var(--shadow-lg), 0 0 0 4px rgba(255, 79, 15, 0.08);
  }

  .comparison-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 1.25rem;
    border-radius: var(--radius-full);
  }

  .comparison-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .comparison-total {
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 0.25rem;
  }

  .comparison-total--accent {
    color: var(--color-primary);
  }

  .comparison-period {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .comparison-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .comparison-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .comparison-item-label {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .comparison-item-value {
    font-weight: 700;
    font-size: 1rem;
  }

  .comparison-verdict {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
  }

  .comparison-verdict--negative {
    background: #fef2f2;
    color: #dc2626;
  }

  .comparison-verdict--positive {
    background: #f0fdf4;
    color: #16a34a;
  }

  /* --- Roadmap --- */
  .roadmap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .roadmap-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
