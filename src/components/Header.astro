---
const currentPath = Astro.url.pathname;

const navLinks = [
  { name: 'Home', path: '/' },
  { name: 'Work', path: '/work/' },
  { name: 'Process', path: '/process/' },
  { name: 'About', path: '/about/' },
  { name: 'Services', path: '/services/' },
];
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-accent">EOD</span>bytes
    </a>

    <!-- Desktop Nav -->
    <nav class="nav-desktop" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.path}
          class:list={['nav-link', { active: currentPath === link.path || currentPath === link.path.slice(0, -1) }]}
        >
          {link.name}
        </a>
      ))}
      <a href="/contact/" class="btn btn--dark nav-cta">Start a Project</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="material-symbols-outlined menu-icon" id="menu-icon">menu</span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav class="nav-mobile" id="nav-mobile" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a
        href={link.path}
        class:list={['nav-mobile-link', { active: currentPath === link.path || currentPath === link.path.slice(0, -1) }]}
      >
        {link.name}
      </a>
    ))}
    <a href="/contact/" class="btn btn--primary nav-mobile-cta">Start a Project</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(252, 249, 248, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .logo-accent {
    color: var(--color-primary);
  }

  /* Desktop Nav */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 769px) {
    .nav-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none;
    }
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(35, 20, 15, 0.8);
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
  }

  .nav-cta {
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
  }

  /* Mobile Button */
  .menu-toggle {
    padding: 0.5rem;
    margin-right: -0.5rem;
    color: var(--color-text-dark);
  }

  .menu-icon {
    font-size: 1.75rem;
  }

  /* Mobile Nav */
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem;
    gap: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    background: var(--color-bg-light);
    overflow: hidden;
    animation: slideMenuDown 0.3s ease forwards;
  }

  @keyframes slideMenuDown {
    from {
      opacity: 0;
      max-height: 0;
    }
    to {
      opacity: 1;
      max-height: 400px;
    }
  }

  .nav-mobile.open {
    display: flex;
  }

  @media (min-width: 769px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-link {
    font-size: 1.125rem;
    font-weight: 500;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    color: var(--color-text-dark);
    transition: color 0.2s;
  }
  .nav-mobile-link.active {
    color: var(--color-primary);
  }

  .nav-mobile-cta {
    margin-top: 1rem;
    text-align: center;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('nav-mobile');
  const icon = document.getElementById('menu-icon');

  if (toggle && nav && icon) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('open');
      icon.textContent = isOpen ? 'close' : 'menu';
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>
