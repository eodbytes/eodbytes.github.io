---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-accent">EOD</span>bytes
        </a>
        <p class="footer-desc">
          Production-first mobile engineering studio. We assemble deployment-ready apps from battle-tested libraries on Kotlin Multiplatform.
        </p>
        <div class="footer-socials">
          <a href="#" class="social-link" aria-label="GitHub">
            <span class="material-symbols-outlined">code</span>
          </a>
          <a href="#" class="social-link" aria-label="Email">
            <span class="material-symbols-outlined">mail</span>
          </a>
        </div>
      </div>

      <!-- Studio Links -->
      <div class="footer-col">
        <h4 class="footer-heading">Studio</h4>
        <ul class="footer-links">
          <li><a href="/work/">Work</a></li>
          <li><a href="/process/">Process</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/services/">Services</a></li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div class="footer-col">
        <h4 class="footer-heading">Contact</h4>
        <ul class="footer-links">
          <li>eodbytes@gmail.com</li>
          <li>Bengaluru, India</li>
          <li class="footer-cta-link">
            <a href="/contact/">
              Book Discovery Call
              <span class="material-symbols-outlined" style="font-size: 0.875rem;">arrow_forward</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p>&copy; {year} EODbytes LLC. All rights reserved.</p>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: 5rem 1.5rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 769px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: 2rem;
    }
  }

  .footer-logo {
    font-size: 1.875rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .logo-accent {
    color: var(--color-primary);
  }

  .footer-desc {
    color: var(--color-white-70);
    max-width: 24rem;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .footer-socials {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--color-white-10);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .social-link:hover {
    background: var(--color-primary);
  }
  .social-link .material-symbols-outlined {
    font-size: 0.875rem;
  }

  .footer-heading {
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-white-70);
  }

  .footer-links a {
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-cta-link {
    padding-top: 1rem;
  }
  .footer-cta-link a {
    color: var(--color-primary);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.2s;
  }
  .footer-cta-link a:hover {
    color: white;
  }

  .footer-bottom {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-white-10);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (min-width: 769px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    transition: color 0.2s;
  }
  .footer-legal a:hover {
    color: var(--color-text-light);
  }
</style>
